{
    "cloudtak_url":   "https://map.demo.tak.nz",
    "cloudtak_token": "etl.<your-cloudtak-api-token>",
    "access_keys": [
        "<generate-with: python3 -c \"import secrets; print(secrets.token_urlsafe(32))\">"
    ],
    "layers": [
        { "id": "acft",     "label": "Aircraft",  "connection": 3 },
        { "id": "vessels",  "label": "Vessels",   "connection": 7 },
        { "id": "contacts", "label": "Contacts" }
    ],
    "iconsets": [
        "66f14976-4b62-4023-8edb-d8d2ebeaa336",
        "f8c9d2a1-4b5e-4c7f-9a8b-1d2e3f4g5h6i"
    ],
    "filters": {
        "acft": [
            "properties.metadata.group != \"None\"",
            "properties.metadata.dbFlags % 2 != 0"
        ],
        "vessels": [
            "properties.metadata.TYPE = 51",
            "properties.metadata.TYPE = 55",
            "properties.metadata.TYPE = 35",
            "$contains(properties.metadata.COT_TYPE, \"a-f-S-C\")",
            "$contains(properties.metadata.COT_TYPE, \"a-f-S-A\")",
            "$contains(properties.metadata.COT_TYPE, \"a-f-S-N-N\")",
            "$contains(properties.metadata.COT_TYPE, \"a-f-S-X-L\")"
        ]
    }
}
